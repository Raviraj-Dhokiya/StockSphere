# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/StockSphere?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d

# ─── Finnhub API ──────────────────────────────────────────────────────────────
# Get free key from: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# ─── CORS (Frontend URL) ──────────────────────────────────────────────────────
# Development: http://localhost:3000
# Production (Vercel): https://your-app.vercel.app
# Multiple origins (comma-separated): https://your-app.vercel.app,http://localhost:3000
CLIENT_URL=http://localhost:3000
