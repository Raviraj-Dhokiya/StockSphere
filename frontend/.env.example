# ─── API URL ──────────────────────────────────────────────────────────────────
# Development: Leave empty (Vite proxy /api → localhost:5000)
# Production (Render): https://your-backend.onrender.com/api
VITE_API_URL=

# ─── Socket URL ───────────────────────────────────────────────────────────────
# Development: Leave empty (auto uses localhost:5000)
# Production (Render): https://your-backend.onrender.com
VITE_SOCKET_URL=
